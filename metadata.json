{
  "name": "android-vision-assistance-sdk",
  "version": "1.0.0",
  "description": "Real-time vision assistance for visually impaired users",
  "platform": "android",
  "category": "accessibility",
  "minSdk": 24,
  "targetSdk": 34,
  "language": "kotlin",
  "buildSystem": "gradle",
  "features": [
    "object-detection",
    "door-detection",
    "stair-detection",
    "obstacle-detection",
    "distance-estimation",
    "voice-feedback"
  ],
  "dependencies": [
    "tensorflow-lite",
    "mediapipe"
  ],
  "permissions": [
    "CAMERA",
    "INTERNET"
  ],
  "tags": ["android", "accessibility", "vision", "visually-impaired"]
}
